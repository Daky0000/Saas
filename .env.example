# Social Media OAuth Configuration
VITE_API_BASE_URL=http://localhost:5000
VITE_APP_URL=http://localhost:3000

# Instagram
VITE_INSTAGRAM_APP_ID=your_instagram_app_id
VITE_INSTAGRAM_REDIRECT_URI=/auth/instagram/callback

# Twitter/X
VITE_TWITTER_CLIENT_ID=your_twitter_client_id
VITE_TWITTER_REDIRECT_URI=/auth/twitter/callback

# LinkedIn
VITE_LINKEDIN_CLIENT_ID=your_linkedin_client_id
VITE_LINKEDIN_REDIRECT_URI=/auth/linkedin/callback

# Facebook
VITE_FACEBOOK_APP_ID=your_facebook_app_id
VITE_FACEBOOK_REDIRECT_URI=/auth/facebook/callback

# TikTok
VITE_TIKTOK_CLIENT_ID=your_tiktok_client_id
VITE_TIKTOK_REDIRECT_URI=/auth/tiktok/callback

# Pinterest
VITE_PINTEREST_CLIENT_ID=your_pinterest_client_id
VITE_PINTEREST_REDIRECT_URI=/auth/pinterest/callback
PINTEREST_CLIENT_SECRET=your_pinterest_client_secret

# Backend Configuration (for backend/server deployment)
BACKEND_PORT=5000
INSTAGRAM_APP_SECRET=your_instagram_app_secret
TWITTER_CLIENT_SECRET=your_twitter_client_secret
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
FACEBOOK_APP_SECRET=your_facebook_app_secret
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
JWT_SECRET=your_jwt_secret_key
INTEGRATIONS_ENCRYPTION_KEY=your_integrations_encryption_key
DATABASE_URL=your_database_url
