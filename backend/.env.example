DATABASE_URL="postgresql://user:password@YOUR_DB_HOST:5432/marketing_platform"
JWT_SECRET="your-secret-key-change-in-production"
NODE_ENV="production"
FRONTEND_URL="https://marketing.dakyworld.com"
BACKEND_URL="https://contentflow-api-production.up.railway.app"
ENCRYPTION_KEY="change-me-32-bytes-key-123456789012"
SEED_DEFAULT_USERS="false"
SEED_DEFAULT_USERS_RETRIES="5"
SEED_DEFAULT_USERS_DELAY_MS="5000"

# Social Media APIs
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-secret"
INSTAGRAM_APP_ID="your-instagram-app-id"
INSTAGRAM_APP_SECRET="your-instagram-secret"
TIKTOK_CLIENT_ID="your-tiktok-client-id"
TIKTOK_CLIENT_SECRET="your-tiktok-secret"
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-secret"
TWITTER_CLIENT_ID="your-twitter-client-id"
TWITTER_CLIENT_SECRET="your-twitter-secret"
PINTEREST_APP_ID="your-pinterest-app-id"
PINTEREST_APP_SECRET="your-pinterest-secret"

# Claude API (for post variations)
ANTHROPIC_API_KEY="your-anthropic-key"

# Email
SENDGRID_API_KEY="your-sendgrid-key"

# Sentry
SENTRY_DSN="your-sentry-dsn"

# Redis (for Bull job queue)
REDIS_URL="redis://YOUR_REDIS_HOST:6379"
