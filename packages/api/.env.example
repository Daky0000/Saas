# API (Express) — SERVER-ONLY secrets
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth
JWT_SECRET=replace-with-strong-random-secret-at-least-32-chars

# Encryption (do NOT reuse JWT secret)
INTEGRATIONS_ENCRYPTION_KEY=replace-with-strong-random-secret-at-least-32-chars
WORDPRESS_ENCRYPTION_KEY=replace-with-strong-random-secret-at-least-32-chars

# CORS (comma-separated)
FRONTEND_ORIGINS=http://localhost:3000

# Error monitoring (strongly recommended in production; no-op when unset)
SENTRY_DSN=

# Resend webhook signing secret (falls back to platform_configs resend.webhookSecret).
# Without one, engagement webhooks are DISCARDED in production.
RESEND_WEBHOOK_SECRET=

# Dev/test only: keep the "User One" account topped up at 1,000,000 credits.
# NEVER set this in production.
ENABLE_TEST_USER_CREDITS=false

# OAuth client secrets (server-side only)
INSTAGRAM_APP_SECRET=your_instagram_app_secret
TWITTER_CLIENT_SECRET=your_twitter_client_secret
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
FACEBOOK_APP_SECRET=your_facebook_app_secret
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
PINTEREST_CLIENT_SECRET=your_pinterest_client_secret
THREADS_APP_SECRET=your_threads_app_secret

