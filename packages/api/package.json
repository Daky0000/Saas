{
  "name": "@contentflow/api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "node .railway-build/server.mjs",
    "build": "esbuild src/server.ts --bundle --platform=node --format=esm --packages=external --external:node:* --outfile=.railway-build/server.mjs && node ../../scripts/copy-web-dist-to-api-public.mjs",
    "test": "node --test --test-concurrency=1 --test-isolation=none"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "form-data": "^4.0.5",
    "helmet": "^8.2.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "pino": "^9.9.0",
    "resend": "^6.12.3",
    "stripe": "^22.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "esbuild": "^0.25.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
