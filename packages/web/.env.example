# Web (Vite) — PUBLIC variables only
VITE_API_BASE_URL=http://localhost:5000
VITE_APP_URL=http://localhost:3000

# OAuth client IDs (safe to expose in frontend)
VITE_INSTAGRAM_APP_ID=your_instagram_app_id
VITE_INSTAGRAM_REDIRECT_URI=http://localhost:3000/auth/instagram/callback

VITE_TWITTER_CLIENT_ID=your_twitter_client_id
VITE_TWITTER_REDIRECT_URI=http://localhost:3000/auth/twitter/callback

VITE_LINKEDIN_CLIENT_ID=your_linkedin_client_id
VITE_LINKEDIN_REDIRECT_URI=http://localhost:3000/auth/linkedin/callback

VITE_FACEBOOK_APP_ID=your_facebook_app_id
VITE_FACEBOOK_REDIRECT_URI=http://localhost:3000/auth/facebook/callback

VITE_TIKTOK_CLIENT_ID=your_tiktok_client_id
VITE_TIKTOK_REDIRECT_URI=http://localhost:3000/auth/tiktok/callback

VITE_PINTEREST_CLIENT_ID=your_pinterest_client_id
VITE_PINTEREST_REDIRECT_URI=http://localhost:3000/auth/pinterest/callback

# Never put client secrets in the web env file.

